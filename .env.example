OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
E2B_API_KEY=your_e2b_api_key_here

# PostgreSQL credentials
POSTGRES_USER=analyst
POSTGRES_PASSWORD=analyst_pass
POSTGRES_DB=autoanalyst

# DATABASE_URL — set to localhost for local runs.
# Docker Compose overrides this automatically with the postgres service hostname.
DATABASE_URL=postgresql://analyst:analyst_pass@localhost:5432/autoanalyst

# LLM choice: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# LangSmith observability (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=autoanalyst-ai
